{
  "providers": {
    "anthropic": {
      "method": "api_key",
      "credential_env": "ANTHROPIC_API_KEY",
      "header": "x-api-key"
    },
    "google": {
      "method": "api_key",
      "credential_env": "GOOGLE_API_KEY",
      "header": "url_param"
    },
    "openrouter": {
      "method": "api_key",
      "credential_env": "OPENROUTER_API_KEY",
      "header": "authorization_bearer"
    }
  }
}
